{
  "name": "@nuxtjs/strapi",
  "version": "2.1.0",
  "description": "Strapi module for Nuxt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nuxt-modules/strapi.git"
  },
  "homepage": "https://strapi.nuxtjs.org",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./dist/module.mjs"
  },
  "main": "./dist/module.mjs",
  "typesVersions": {
    "*": {
      ".": [
        "./dist/module.d.mts"
      ]
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "nuxt-module-build build",
    "prepack": "pnpm build",
    "dev": "nuxi dev playground",
    "dev:build": "nuxi build playground",
    "dev:prepare": "nuxt-module-build build --stub && nuxt-module-build prepare && nuxi prepare playground && nuxi prepare docs",
    "docs": "docus dev docs",
    "docs:build": "docus build docs",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "release": "pnpm lint && standard-version && git push --follow-tags"
  },
  "dependencies": {
    "@nuxt/kit": "^3.17.5",
    "defu": "^6.1.4",
    "graphql": "^16.11.0",
    "qs": "^6.14.0",
    "ufo": "^1.6.1"
  },
  "devDependencies": {
    "@nuxt/devtools": "^2.5.0",
    "@nuxt/eslint-config": "^1.4.1",
    "@nuxt/module-builder": "^1.0.1",
    "eslint": "^9.29.0",
    "nuxt": "^3.17.5",
    "standard-version": "^9.5.0",
    "typescript": "^5.6.3",
    "vue-tsc": "^2.2.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "resolutions": {
    "@nuxtjs/strapi": "workspace:*",
    "typescript": "5.6.3"
  }
}
